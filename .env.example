# LinkedIn AutoPilot v2
# Copy this file to `.env.local` and fill in your credentials

# ============================================================
# Gemini / Vertex AI
# ============================================================
GOOGLE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"YOUR_PROJECT","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"SERVICE_ACCOUNT_EMAIL@PROJECT.iam.gserviceaccount.com"}
GOOGLE_CLOUD_PROJECT=ai-agent-cha-2y53
GOOGLE_CLOUD_LOCATION=global
GEMINI_MODEL=gemini-2.5-flash

# ============================================================
# GitHub (as database)
# ============================================================
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GITHUB_REPO=YourUsername/your-repo-name

# ============================================================
# LinkedIn
# ============================================================
LINKEDIN_ACCESS_TOKEN=AQVYXXXXXXXXXXXXXXXXXXXXXX
LINKEDIN_USER_URN=urn:li:person:XXXXXXXXX

# ============================================================
# Security
# ============================================================
# Required to access the dashboard and API routes
API_SECRET=your-secret-key-change-in-production
# Required to call the /api/cron endpoint from Vercel
CRON_SECRET=your-cron-secret-key
