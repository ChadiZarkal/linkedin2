# LinkedIn API Credentials - Template
# Copiez ce fichier en '.env' et remplissez vos valeurs

# Identifiants de l'application (à trouver dans LinkedIn Dev Portal)
LINKEDIN_CLIENT_ID=YOUR_CLIENT_ID_HERE
LINKEDIN_CLIENT_SECRET=YOUR_CLIENT_SECRET_HERE

# Token d'accès (généré via OAuth flow)
LINKEDIN_ACCESS_TOKEN=YOUR_ACCESS_TOKEN_HERE

# Vos informations personnelles
LINKEDIN_USER_ID=YOUR_USER_ID_HERE
LINKEDIN_USER_URN=urn:li:person:YOUR_USER_ID_HERE
LINKEDIN_USER_EMAIL=your.email@gmail.com
LINKEDIN_USER_NAME=Your Full Name

# Paramètres de publication
LINKEDIN_PUBLISHING_CONTENT_TYPE=TEXT
LINKEDIN_PUBLISHING_VISIBILITY=PUBLIC
